{
  "$id": "https://opendatafabric.org/schemas/config/v1alpha1/Variable.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Individual variable.",
  "format": "struct-or-string",
  "oneOf": [
    {
      "type": "string"
    },
    {
      "type": "object",
      "required": [
        "value"
      ],
      "properties": {
        "value": {
          "type": "string",
          "description": "A value in raw or encoded form."
        }
      }
    }
  ]
}
