{
  "$id": "https://opendatafabric.org/schemas/source/v1alpha1/MqttTopicSubscription.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "MQTT topic subscription parameters.",
  "type": "object",
  "required": [
    "path"
  ],
  "properties": {
    "path": {
      "type": "string",
      "description": "Name of the topic (may include patterns)."
    },
    "qos": {
      "$ref": "https://opendatafabric.org/schemas/source/v1alpha1/MqttQos.json",
      "description": "Quality of service class.",
      "default": "AtMostOnce",
      "unevaluatedProperties": false
    }
  }
}
