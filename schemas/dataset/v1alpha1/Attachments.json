{
  "$id": "https://opendatafabric.org/schemas/dataset/v1alpha1/Attachments",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Defines the source of attachment files.",
  "$defs": {
    "Embedded": {
      "description": "For attachments that are specified inline and are embedded in the metadata.",
      "type": "object",
      "required": [
        "items"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "https://opendatafabric.org/schemas/dataset/v1alpha1/AttachmentEmbedded",
            "unevaluatedProperties": false
          },
          "description": "List of embedded items."
        }
      }
    }
  },
  "oneOf": [
    {
      "allOf": [
        {
          "properties": {
            "kind": {
              "type": "string",
              "const": "Embedded"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "$ref": "#/$defs/Embedded"
        }
      ]
    }
  ]
}
