{
  "$id": "https://opendatafabric.org/schemas/dataset/v1alpha1/Seed",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Establishes the identity of the dataset. Always the first metadata event in the chain.",
  "type": "object",
  "required": [
    "datasetId",
    "datasetKind"
  ],
  "properties": {
    "datasetId": {
      "type": "string",
      "format": "dataset-id",
      "description": "Unique identity of the dataset."
    },
    "datasetKind": {
      "$ref": "https://opendatafabric.org/schemas/dataset/v1alpha1/DatasetKind",
      "description": "Type of the dataset.",
      "unevaluatedProperties": false
    }
  }
}
