{
  "$id": "https://opendatafabric.org/schemas/dataset/v1alpha1/SetTransform.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Defines a transformation that produces data in a derivative dataset.",
  "type": "object",
  "required": [
    "inputs",
    "transform"
  ],
  "properties": {
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "https://opendatafabric.org/schemas/dataset/v1alpha1/TransformInput.json",
        "unevaluatedProperties": false
      },
      "description": "Datasets that will be used as sources."
    },
    "transform": {
      "$ref": "https://opendatafabric.org/schemas/dataset/v1alpha1/Transform.json",
      "description": "Transformation that will be applied to produce new data.",
      "unevaluatedProperties": false
    }
  }
}
