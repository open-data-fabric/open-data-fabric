{
  "$id": "https://opendatafabric.org/schemas/dataset/v1alpha1/ProjectionSpecInput",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "canonicalType": "https://opendatafabric.org/schemas/dataset/v1alpha1/ProjectionSpec",
  "description": "Represents a projection of a dataaset history into a state for fast lookups.",
  "type": "object",
  "required": [
    "inputs",
    "project"
  ],
  "properties": {
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "https://opendatafabric.org/schemas/dataset/v1alpha1/TransformInput",
        "unevaluatedProperties": false
      },
      "description": "Datasets that will be used as sources."
    },
    "project": {
      "$ref": "https://opendatafabric.org/schemas/dataset/v1alpha1/Transform",
      "description": "Transformation that will be applied to produce new data.",
      "unevaluatedProperties": false
    }
  }
}
