{
  "$id": "https://opendatafabric.org/schemas/auth/v1alpha1/AccountHandle",
  "$schema": "https://opendatafabric.org/schemas/metaschemas/v1alpha1/ResourceHandle",
  "description": "Link to an account.",
  "type": "object",
  "required": [
    "id",
    "did",
    "name"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "resource-id",
      "description": "ID of the account resource."
    },
    "did": {
      "type": "string",
      "format": "account-id",
      "description": "DID of the account."
    },
    "name": {
      "type": "string",
      "format": "account-name",
      "description": "Name of the account."
    }
  }
}