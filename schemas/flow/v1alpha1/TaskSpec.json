{
  "$id": "https://opendatafabric.org/schemas/flow/v1alpha1/TaskSpec.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "An individual work item to be executed as part of a flow.",
  "$defs": {
    "Ingest": {
      "description": "Fetches data from a source and appends it to a dataset.",
      "type": "object",
      "required": [
        "source",
        "dataset"
      ],
      "properties": {
        "source": {
          "$ref": "https://opendatafabric.org/schemas/resource/v1alpha1/ResourceRef.json",
          "description": "Reference to the source resource that defines how to fetch data.",
          "unevaluatedProperties": false
        },
        "dataset": {
          "$ref": "https://opendatafabric.org/schemas/resource/v1alpha1/ResourceRef.json",
          "description": "Reference to the dataset resource to ingest data into.",
          "unevaluatedProperties": false
        },
        "params": {
          "$ref": "https://opendatafabric.org/schemas/flow/v1alpha1/IngestParams.json",
          "description": "Optional parameters to control ingestion behavior.",
          "unevaluatedProperties": false
        }
      }
    },
    "Compaction": {
      "description": "Compacts data files in matching datasets to improve query performance.",
      "type": "object",
      "required": [
        "dataset"
      ],
      "properties": {
        "dataset": {
          "$ref": "https://opendatafabric.org/schemas/flow/v1alpha1/DatasetSelector.json",
          "description": "Selector identifying which datasets to compact.",
          "unevaluatedProperties": false
        },
        "maxSliceSize": {
          "type": "string",
          "format": "byte-size",
          "description": "Target maximum size of each compacted data slice e.g. `100MiB`."
        },
        "maxSliceRecords": {
          "type": "integer",
          "format": "uint64",
          "description": "Target maximum number of records per compacted data slice."
        }
      }
    },
    "GarbageCollection": {
      "description": "Removes unreferenced data files from matching datasets.",
      "type": "object",
      "required": [
        "dataset"
      ],
      "properties": {
        "dataset": {
          "$ref": "https://opendatafabric.org/schemas/flow/v1alpha1/DatasetSelector.json",
          "description": "Selector identifying which datasets to garbage collect.",
          "unevaluatedProperties": false
        }
      }
    }
  },
  "oneOf": [
    {
      "allOf": [
        { "properties": { "kind": { "type": "string", "const": "Ingest" } }, "required": ["kind"] },
        { "$ref": "#/$defs/Ingest" }
      ]
    },
    {
      "allOf": [
        { "properties": { "kind": { "type": "string", "const": "Compaction" } }, "required": ["kind"] },
        { "$ref": "#/$defs/Compaction" }
      ]
    },
    {
      "allOf": [
        { "properties": { "kind": { "type": "string", "const": "GarbageCollection" } }, "required": ["kind"] },
        { "$ref": "#/$defs/GarbageCollection" }
      ]
    }
  ]
}
