{
  "$id": "https://opendatafabric.org/schemas/flow/v1alpha1/FlowSpec.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Defines a sequence of tasks to be executed upon certain trigger conditions.",
  "type": "object",
  "required": [
    "tasks"
  ],
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "https://opendatafabric.org/schemas/flow/v1alpha1/TaskSpec.json"
      },
      "description": "List of tasks to run consecutively."
    }
  }
}
