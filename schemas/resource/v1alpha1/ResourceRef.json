{
  "$id": "https://opendatafabric.org/schemas/resource/v1alpha1/ResourceRef",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Reference to another resource.",
  "format": "struct-or-string",
  "oneOf": [
    {
      "type": "string"
    },
    {
      "type": "object",
      "codegen": {
        "rust": {
          "dtoType": "ResourceRef"
        }
      },
      "required": [
        "type"
      ],
      "properties": {
        "account": {
          "$ref": "https://opendatafabric.org/schemas/auth/v1alpha1/AccountRef",
          "description": "Reference to an account that owns the target resource.",
          "unevaluatedProperties": false
        },
        "type": {
          "type": "string",
          "format": "resource-type-ref",
          "examples": [
            "SecretSet",
            "https://opendatafabric.org/config/v1/SecretSet"
          ],
          "description": "Short type name or full type URI of the target resource."
        },
        "id": {
          "type": "string",
          "format": "resource-id",
          "description": "ID of a resource."
        },
        "name": {
          "type": "string",
          "format": "resource-name",
          "description": "Name of a resource."
        }
      }
    }
  ]
}